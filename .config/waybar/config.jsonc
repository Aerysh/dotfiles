// -*- mode: jsonc -*-
{
  "include": "$HOME/.config/waybar/modules.jsonc",
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "passthrough": false,
  "fixed-center": true,
  "ipc": true,
  "spacing": 4,
  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": [],
  "modules-right": [
    "network",
    "idle_inhibitor",
    "memory",
    "cpu",
    "pulseaudio",
    "battery",
    "backlight",
    "clock",
    "tray",
    "custom/power",
  ],
}
