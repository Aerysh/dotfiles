{
  "include": "$HOME/.config/waybar/modules.jsonc",
  "layer": "top",
  "exclusive": true,
  "passthrough": false,
  "position": "top",
  "fixed-center": true,
  "ipc": true,
  "spacing": 4,
  "margin-top": 4,
  "margin-left": 4,
  "margint-right": 4,
  "modules-left": ["backlight", "battery", "idle_inhibitor"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["tray", "custom/notification", "group/system"],
}
